#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <sys/socket.h>
#include <netdb.h>
#include <time.h>

#define BUF_SIZE 4096
#define DROP_PROB 0.01
#define DATA_SIZE 1000  // must match sender

int rev_packet(const char *buf, size_t buf_len,
               unsigned int *total_frag,
               unsigned int *frag_no,
               unsigned int *size,
               char *filename,
               size_t filename_cap,
               size_t *data_start)
{
    size_t col[4];
    int count = 0;

    for (size_t i = 0; i < buf_len && count < 4; i++) {
        if (buf[i] == ':') {
            col[count++] = i;
        }
    }
    if (count < 4) return 0;

    // avoid overflow
    if (col[0] >= 31 || (col[1] - col[0] - 1) >= 31 || (col[2] - col[1] - 1) >= 31)
        return 0;

    char a[32], b[32], c[32];
    memcpy(a, buf, col[0]); a[col[0]] = '\0';
    memcpy(b, buf + col[0] + 1, col[1] - col[0] - 1); b[col[1] - col[0] - 1] = '\0';
    memcpy(c, buf + col[1] + 1, col[2] - col[1] - 1); c[col[2] - col[1] - 1] = '\0';

    size_t fname_len = col[3] - col[2] - 1;
    if (fname_len + 1 > filename_cap) return 0;   // prevent filename overflow
    memcpy(filename, buf + col[2] + 1, fname_len);
    filename[fname_len] = '\0';

    *total_frag = (unsigned int)atoi(a);
    *frag_no    = (unsigned int)atoi(b);
    *size       = (unsigned int)atoi(c);
    *data_start = col[3] + 1;

    if (*data_start + *size > buf_len) return 0;
    return 1;
}

void send_ctrl(int sockfd, struct sockaddr *client, socklen_t client_len,
               const char *type, unsigned int frag_no)
{
    char msg[64];
    int n = snprintf(msg, sizeof(msg), "%s:%u", type, frag_no);
    sendto(sockfd, msg, n, 0, client, client_len);
}

static int drop_pkt(void)
{
    double r = (double)rand() / ((double)RAND_MAX + 1.0);
    return (r < DROP_PROB);
}

int main(int argc, char *argv[])
{
    if (argc != 2) {
        printf("Usage: %s <port>\n", argv[0]);
        return 1;
    }

    srand((unsigned int)time(NULL));

    struct addrinfo hints, *res;
    memset(&hints, 0, sizeof hints);
    hints.ai_family = AF_INET;
    hints.ai_socktype = SOCK_DGRAM;
    hints.ai_flags = AI_PASSIVE;

    int gai = getaddrinfo(NULL, argv[1], &hints, &res);
    if (gai != 0) {
        fprintf(stderr, "getaddrinfo: %s\n", gai_strerror(gai));
        return 1;
    }

    int sockfd = socket(res->ai_family, res->ai_socktype, res->ai_protocol);
    if (sockfd < 0) { perror("socket"); freeaddrinfo(res); return 1; }

    if (bind(sockfd, res->ai_addr, res->ai_addrlen) < 0) {
        perror("bind");
        freeaddrinfo(res);
        close(sockfd);
        return 1;
    }
    freeaddrinfo(res);

    printf("Server listening on port %s...\n", argv[1]);

    FILE *fp = NULL;
    char filename[256];
    char buf[BUF_SIZE];

    unsigned int expected_frag = 1;
    unsigned int current_total = 0;
    char current_name[256] = {0};

    while (1) {
        struct sockaddr_storage client;
        socklen_t client_len = sizeof(client);

        ssize_t n = recvfrom(sockfd, buf, sizeof(buf), 0,
                             (struct sockaddr *)&client, &client_len);
        if (n < 0) { perror("recvfrom"); continue; }

        unsigned int total_frag, frag_no, size;
        size_t data_start;

        if (!rev_packet(buf, (size_t)n, &total_frag, &frag_no, &size,
                        filename, sizeof(filename), &data_start)) {
            send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "NACK", expected_frag);
            continue;
        }

        // Simulate drop
        if (drop_pkt()) {
            printf("[DROP] frag %u/%u (%s)\n", frag_no, total_frag, filename);
            continue; // sender will timeout and retransmit
        }

        // Start of a new transfer (only when we truly expect frag 1)
        if (expected_frag == 1 && frag_no == 1) {
            if (fp) { fclose(fp); fp = NULL; }
            fp = fopen(filename, "wb");
            if (!fp) {
                send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "NACK", frag_no);
                continue;
            }
            current_total = total_frag;
            strncpy(current_name, filename, sizeof(current_name) - 1);
            current_name[sizeof(current_name) - 1] = '\0';
            printf("Receiving file: %s (%u fragments)\n", current_name, current_total);
        }

        // If we haven't started properly yet, reject
        if (!fp) {
            send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "NACK", 1);
            continue;
        }

        // Duplicate fragment: ACK again, but DO NOT write
        if (frag_no < expected_frag) {
            send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "ACK", frag_no);
            continue;
        }

        // Out-of-order: ask for the fragment we want
        if (frag_no > expected_frag) {
            send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "NACK", expected_frag);
            continue;
        }

        // Correct in-order fragment
        // (Optional but safe) Seek to exact offset in case you ever change to sliding window:
        // fseek(fp, (long)(frag_no - 1) * DATA_SIZE, SEEK_SET);

        fwrite(buf + data_start, 1, size, fp);
        send_ctrl(sockfd, (struct sockaddr *)&client, client_len, "ACK", frag_no);

        expected_frag++;

        // Done
        if (frag_no == current_total) {
            fclose(fp);
            fp = NULL;
            printf("File %s received successfully.\n", current_name);
            break;
        }
    }

    close(sockfd);
    return 0;
}
